# ===========================================
# Tube Sync Configuration
# Copy this file to .env and edit as needed
# ===========================================

# Video quality: best, 1080p, 720p, 480p
VIDEO_QUALITY=best

# Maximum concurrent downloads
MAX_CONCURRENT_DOWNLOADS=3

# ===========================================
# SMB Upload Configuration (optional)
# ===========================================
SMB_ENABLED=false
SMB_HOST=192.168.1.100
SMB_SHARE=video
SMB_USER=username
SMB_PASSWORD=password
SMB_PATH=/youtube
SMB_SHORTS_PATH=/shorts

# ===========================================
# FTP Upload Configuration (optional)
# ===========================================
FTP_ENABLED=false
FTP_HOST=192.168.1.100
FTP_PORT=21
FTP_USER=username
FTP_PASSWORD=password
FTP_PATH=/youtube
FTP_SHORTS_PATH=/shorts
FTP_USE_TLS=false

# ===========================================
# General Settings
# ===========================================
DELETE_AFTER_UPLOAD=false
SHORTS_MAX_DURATION=60
