# ===========================================
# YT Downloader Configuration
# Copy this file to .env and edit as needed
# ===========================================

# Download directory (inside container)
DOWNLOAD_DIR=/app/downloads

# Database path
DATABASE_URL=sqlite+aiosqlite:///./data/videos.db

# Video quality: best, 1080p, 720p, 480p
VIDEO_QUALITY=best

# Maximum concurrent downloads
MAX_CONCURRENT_DOWNLOADS=3

# ===========================================
# NAS Upload Configuration (optional)
# ===========================================
NAS_ENABLED=false
NAS_HOST=192.168.1.100
NAS_SHARE=video
NAS_USER=username
NAS_PASSWORD=password
NAS_PATH=/youtube
NAS_SHORTS_PATH=/shorts
NAS_DELETE_AFTER_UPLOAD=false
SHORTS_MAX_DURATION=60

# ===========================================
# YouTube API Configuration (optional)
# For personalized subscription downloads
# ===========================================
# These are mounted as volumes, paths inside container:
YOUTUBE_TOKEN_FILE=/app/youtube_token.json
YOUTUBE_CLIENT_FILE=/app/google-client.json
