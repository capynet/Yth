#!/usr/bin/env python3
"""
YT Sync CLI - Dashboard for monitoring downloads and uploads.
"""

import sys
import os

# Add the app directory to path
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

# Import and run the CLI
from app.ytcli import main

if __name__ == "__main__":
    # Default to watch mode if no arguments
    if len(sys.argv) == 1:
        sys.argv.append("-w")
    main()
